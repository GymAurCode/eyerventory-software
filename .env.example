# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ─── AI Assistant (LLM) ───────────────────────────────────────────────────────
# Add your Google Gemini API key to enable natural language responses in the AI chat.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override the model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# URL of the deployed license service (Railway, Render, etc.)
LICENSE_SERVER_URL=https://your-app.railway.app

# Vite frontend (must be prefixed with VITE_ to be exposed to the browser)
VITE_LICENSE_SERVER_URL=https://your-app.railway.app

# HMAC signing secret for tokens — use a long random string in production
LICENSE_SECRET=change-this-to-a-long-random-string

# Admin password for /seed and /revoke endpoints — only you need this
LICENSE_ADMIN_SECRET=your-admin-password-here
