{
  "name": "EyerFlow",
  "version": "1.0.4",  
  "description": "Production Inventory Management System desktop app",
  "main": "electron/main.js",
  "author": "Eyercall",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "npm run dev:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "node scripts/build-backend.js",
    "build": "npm run build:frontend && npm run build:backend && electron-builder",
    "dist": "npm run build"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.eyerflow.app",
    "productName": "EyerFlow",
    "artifactName": "EyerFlow-${version}.${ext}",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EyerFlow",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeader": "assets/icon.ico",
      "installerSidebar": null,
      "include": null
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GymAurCode",
        "repo": "eyerflow-software",
        "releaseType": "release",
        "publishAutoUpdate": true
      }
    ]
  }
}
